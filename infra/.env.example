# === Artifact backend ===
DV_ARTIFACT_BACKEND=s3
DV_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniopass

# === MinIO ===
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniopass

# === Postgres ===
# `mlflow` + `prefect` DBs are created by postgres-init.sql in the default
# `postgres` DB, so POSTGRES_DB is intentionally omitted (defaults to postgres).
POSTGRES_USER=dv
POSTGRES_PASSWORD=dv

# === MLflow ===
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://dv:dv@postgres:5432/mlflow
MLFLOW_ARTIFACTS_DESTINATION=s3://deepvogue-mlflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# === Prefect ===
PREFECT_API_URL=http://prefect:4200/api
PREFECT_SERVER_DATABASE_CONNECTION_URL=postgresql+asyncpg://dv:dv@postgres:5432/prefect

# === FastAPI inference ===
DV_MODELS_YAML=s3://deepvogue-models/models.yaml
DV_MODELS_ROOT=s3://deepvogue-models

# === Slack ===
# Set to your incoming webhook URL to enable. Empty = silent no-op.
SLACK_WEBHOOK_URL=

# === RunPod training backend ===
#
# LAUNCHER (your laptop / CI) needs these set in its environment:
#   RUNPOD_API_KEY                       runpod.io/console/user/settings
#   RUNPOD_IMAGE                         ghcr.io/<owner>/deepvogue-train:latest
#   GOOGLE_APPLICATION_CREDENTIALS_JSON  full SA JSON (`cat trainer-key.json`)
#   DV_DATASET_URI / DV_RUN_URI / DV_PUBLISH_TARGET  all gs://...
#
# Optional launcher tunables:
#   RUNPOD_GPU_TYPE          GPU SKU; default H100 80GB
#   RUNPOD_VOLUME_GB         persistent volume (default 0 — outputs mirror to GCS)
#   RUNPOD_CONTAINER_DISK_GB ephemeral container disk (default 100)
#   RUNPOD_MAX_TRAIN_HOURS   hard timeout; pod is force-terminated past this (default 24)
#
# These are forwarded INTO the pod automatically — do not set them on the pod yourself:
#   DV_DATASET_URI, DV_RUN_URI, DV_MODEL_ID, DV_CFG, DV_KIMG, DV_GAMMA, DV_BATCH,
#   DV_RES, DV_PUBLISH_TARGET, GOOGLE_APPLICATION_CREDENTIALS_JSON, RUNPOD_API_KEY,
#   MLFLOW_TRACKING_URI, SLACK_WEBHOOK_URL.

RUNPOD_API_KEY=
RUNPOD_IMAGE=
RUNPOD_GPU_TYPE=NVIDIA H100 80GB HBM3
RUNPOD_VOLUME_GB=0
RUNPOD_CONTAINER_DISK_GB=100
RUNPOD_MAX_TRAIN_HOURS=24

# Paste the contents of trainer-key.json on a single line, escaped, or `set -a; source` an env file.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

DV_DATASET_URI=
DV_RUN_URI=
DV_PUBLISH_TARGET=

