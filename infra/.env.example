# === Artifact backend ===
DV_ARTIFACT_BACKEND=s3
DV_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniopass

# === MinIO ===
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniopass

# === Postgres ===
# `mlflow` + `prefect` DBs are created by postgres-init.sql in the default
# `postgres` DB, so POSTGRES_DB is intentionally omitted (defaults to postgres).
POSTGRES_USER=dv
POSTGRES_PASSWORD=dv

# === MLflow ===
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://dv:dv@postgres:5432/mlflow
MLFLOW_ARTIFACTS_DESTINATION=s3://deepvogue-mlflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# === Prefect ===
PREFECT_API_URL=http://prefect:4200/api
PREFECT_SERVER_DATABASE_CONNECTION_URL=postgresql+asyncpg://dv:dv@postgres:5432/prefect

# === FastAPI inference ===
DV_MODELS_YAML=s3://deepvogue-models/models.yaml
DV_MODELS_ROOT=s3://deepvogue-models

# === Slack ===
# Set to your incoming webhook URL to enable. Empty = silent no-op.
SLACK_WEBHOOK_URL=

# === RunPod training backend ===
# RUNPOD_API_KEY  Personal API key from runpod.io/console/user/settings
# RUNPOD_IMAGE    Pushed train image, e.g. ghcr.io/<owner>/deepvogue-train:latest
# RUNPOD_GPU_TYPE GPU SKU; default H100 80GB; e.g. "NVIDIA A40", "NVIDIA RTX A6000"
# RUNPOD_VOLUME_GB Persistent volume size for the pod (default 50)
RUNPOD_API_KEY=
RUNPOD_IMAGE=
RUNPOD_GPU_TYPE=NVIDIA H100 80GB HBM3
RUNPOD_VOLUME_GB=50

# DV_DATASET_URI / DV_RUN_URI / DV_PUBLISH_TARGET are read at pod-launch time
# and forwarded into the container env. Use gs:// URIs for the RunPod backend.
DV_DATASET_URI=
DV_RUN_URI=
DV_PUBLISH_TARGET=

